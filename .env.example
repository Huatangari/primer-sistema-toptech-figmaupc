# BuildTrack environment variables
# Copy to .env.local and fill with your values.
# Never commit .env.local.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Demo mode
# true  -> allows demo login/bypass for local demos
# false -> requires Supabase auth (recommended for staging/prod)
VITE_ALLOW_DEMO_MODE=false

# Observability (optional)
VITE_SENTRY_DSN=

# App metadata
# development | staging | production | preview
VITE_APP_ENV=development
VITE_APP_VERSION=local

# Legacy API base (optional, kept for compatibility)
VITE_API_URL=http://localhost:3000/api
