# =============================================================================
# TopTech — Variables de entorno
# Copia este archivo a .env.local y completa los valores:
#   cp .env.example .env.local
#
# NUNCA subas .env.local al repositorio.
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Obten estos valores en:
# https://supabase.com/dashboard/project/<tu-proyecto>/settings/api
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica

# ── Modo demo ────────────────────────────────────────────────────────────────
# true  → permite login demo y bypass de auth en rutas protegidas.
# false → exige Supabase configurado (recomendado para QA y producción).
VITE_ALLOW_DEMO_MODE=false

# ── Observabilidad (Sentry) ──────────────────────────────────────────────────
# Obtener en: https://sentry.io → Settings → Projects → <proyecto> → DSN
# Dejar vacío para deshabilitar Sentry (p.ej. en desarrollo local).
VITE_SENTRY_DSN=

# ── Entorno y versión ────────────────────────────────────────────────────────
# Valores posibles: development | staging | production
# En CI/CD se inyecta automáticamente por el workflow.
VITE_APP_ENV=development
VITE_APP_VERSION=local

# ── Legacy (deprecado) ───────────────────────────────────────────────────────
# Reemplazado por Supabase client. Mantener por compatibilidad hasta Sprint 5.
VITE_API_URL=http://localhost:3000/api
